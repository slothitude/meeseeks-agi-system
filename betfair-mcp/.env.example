# Betfair API Configuration
# Get your app key from: https://developer.betfair.com/

# Your Betfair Application Key
BETFAIR_APP_KEY=your_app_key_here

# Session Token (obtained via login/certificate auth)
# You'll need to implement auth or obtain this manually
BETFAIR_SESSION_TOKEN=your_session_token_here

# Optional: Use Australian exchange endpoint
# BETFAIR_AUSTRALIAN=true
