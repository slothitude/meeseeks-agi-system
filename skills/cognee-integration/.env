# Cognee Configuration for Meeseeks Consciousness Stack

# LLM Provider - Local Ollama (ministral-3 - supports tools)
LLM_PROVIDER=openai
LLM_MODEL=openai/ministral-3:latest
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama

# Alternative: ZAI Coding API (better quality but connection issues)
# LLM_PROVIDER=openai
# LLM_MODEL=GLM-4.7
# LLM_ENDPOINT=https://api.z.ai/api/coding/paas/v4
# LLM_API_KEY=${ZAI_API_KEY}

# Fallback: Local Ollama (phi3:mini - faster but lower quality)
# LLM_PROVIDER=ollama
# LLM_MODEL=phi3:mini
# LLM_ENDPOINT=http://localhost:11434
# LLM_API_KEY=ollama

# Embedding Provider - Using Ollama nomic-embed-text (native Ollama)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_ENDPOINT=http://localhost:11434
EMBEDDING_DIMENSIONS=768
# HuggingFace tokenizer for token counting (required by cognee even with Ollama)
HUGGINGFACE_TOKENIZER=bert-base-uncased

# Skip connection tests (we know endpoints work)
COGNEE_SKIP_CONNECTION_TEST=true
SYSTEM_ROOT_DIRECTORY=C:\Users\aaron\.openclaw\workspace\the-crypt\cognee

# Disable multi-user access control for single-user setup
ENABLE_BACKEND_ACCESS_CONTROL=false

# Graph Database - Using Kuzu (embedded)
GRAPH_DATABASE_PROVIDER=kuzu

# Vector Database - Using LanceDB (embedded)
VECTOR_DATABASE_PROVIDER=lancedb
